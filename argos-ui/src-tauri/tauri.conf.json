{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArgOS",
  "version": "0.2.0",
  "identifier": "com.argos.app",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm install && pnpm dev"
  },
  "app": {
    "windows": [
      {
        "title": "ArgOS",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
